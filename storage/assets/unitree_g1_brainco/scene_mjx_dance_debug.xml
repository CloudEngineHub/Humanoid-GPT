<mujoco model="g1 mjx flat terrain scene">
    <!-- <include file="g1_mjx_dance.xml"/> -->
    <!-- <include file="G1_inspire_hands.xml"/> -->
    <include file="G1_brainco_hands.xml"/>
    <include file="debug_axis.xml"/>

    <statistic center="0 0 0.8" extent="1.2" meansize="0.02"/>

    <visual>
        <headlight diffuse=".9 .9 .9" ambient=".2 .2 .2" specular="1 1 1"/>
        <rgba force="1 0 0 1"/>
        <!-- 相机视角设置 -->
        <!-- 常用视角选项：
            正面视角: azimuth="0" elevation="0"
            侧面视角: azimuth="90" elevation="0" 
            背面视角: azimuth="180" elevation="0"
            俯视视角: azimuth="0" elevation="-45"
            当前设置: azimuth="140" elevation="-20" (右前方俯视)
        -->
        <global azimuth="180" elevation="-20"  offwidth = "1920" offheight="1080"/>
        
        <map force="0.01"/>
        <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
                 markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <geom name="floor" size="0 0 0.01" type="plane" material="groundplane"/>
    </worldbody>

</mujoco>
